// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model House {
  id        String    @id @default(cuid())
  name      String
  schoolId  String
  school    School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  students  Student[]

  @@unique([name, schoolId])
}

model Programme {
  id        String    @id @default(cuid())
  name      String
  schoolId  String
  school    School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  students  Student[]

  @@unique([name, schoolId])
}

model Route {
  id              String      @id @default(cuid())
  name            String
  schoolId        String
  priceToSchool   Float
  priceFromSchool Float
  school          School      @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  stops           RouteStop[]
  bookings        Booking[]

  @@unique([name, schoolId])
}

model RouteStop {
  id      String @id @default(cuid())
  name    String
  routeId String
  route   Route  @relation(fields: [routeId], references: [id], onDelete: Cascade)

  @@unique([name, routeId])
}

model Student {
  id            String    @id @default(cuid())
  studentName   String
  class         String
  schoolId      String
  houseId       String
  programmeId   String
  email         String
  parentName    String
  parentContact String
  createdAt     DateTime  @default(now())
  school        School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  house         House     @relation(fields: [houseId], references: [id])
  programme     Programme @relation(fields: [programmeId], references: [id])
  bookings      Booking[]
}

model School {
  id           String        @id @default(cuid())
  name         String        @unique
  parentVisits ParentVisit[]
  houses       House[]
  programmes   Programme[]
  routes       Route[]
  students     Student[]
}

model ParentVisit {
  id            String    @id @default(cuid())
  parentName    String
  parentContact String
  email         String
  schoolId      String
  createdAt     DateTime  @default(now())
  school        School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  bookings      Booking[]
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

enum BookingType {
  STUDENT_TRIP
  PARENT_VISIT
}

enum TripType {
  ONE_WAY_TO_SCHOOL
  ONE_WAY_FROM_SCHOOL
}

model Booking {
  id               String        @id @default(cuid())
  studentId        String?
  parentVisitId    String?
  userId           String?
  routeId          String?
  tripType         TripType?     @default(ONE_WAY_TO_SCHOOL)
  stopName         String?       // the chosen route stop
  customDropoff    String?       // free-text if stop not in list
  price            Float
  paymentReference String?       @unique
  paymentStatus    PaymentStatus @default(PENDING)
  type             BookingType   @default(STUDENT_TRIP)
  createdAt        DateTime      @default(now())
  student          Student?      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  parentVisit      ParentVisit?  @relation(fields: [parentVisitId], references: [id], onDelete: Cascade)
  route            Route?        @relation(fields: [routeId], references: [id])
}
